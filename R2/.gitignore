# ============================================
# Claude Code & AI tooling (local only)
# ============================================
.claude/
**/.claude/

# ============================================
# EmbeddedSkills tool state (local only)
# ============================================
**/.embeddedskills/

# ============================================
# VSCode (keep shared config, exclude logs)
# ============================================
.vscode/*.log
.vscode/*.log.lock
# Allow only these shared configs:
# .vscode/c_cpp_properties.json
# .vscode/settings.json
# .vscode/tasks.json
# .vscode/launch.json

# ============================================
# Keil MDK user & build artifacts
# ============================================
# User-specific (editor layout, debug settings)
*.uvoptx
*.uvguix.*
*.Administrator

# Build outputs
*.hex
*.bin
*.axf
*.elf
*.o
*.d
*.crf
*.dep
*.iex
*.htm
*.lnp
*.plg
*.map
*.fed
*.lst

# Build config (auto-generated by IDE)
JLinkSettings.ini
*.ini

# Scatter file loaded by IDE
*.scvd
*.uvgui.*
*.scvd

# Debug config
DebugConfig/

# RTE directory
RTE/

# Build directories
.build/
build/
*/build/
**/build/

# ============================================
# STM32CubeMX generated (keep .ioc only)
# ============================================
.mxproject

# ============================================
# OS junk
# ============================================
Thumbs.db
.DS_Store
*.swp
*.swo
*~
